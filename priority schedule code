#include <stdio.h>

void nonPreemptivePriority(int n, int bt[], int pr[])
{
    int p[n], wt[n], tat[n];

    for(int i = 0; i < n; i++)
        p[i] = i + 1;

    for(int i = 0; i < n - 1; i++)
    {
        for(int j = i + 1; j < n; j++)
        {
            if(pr[i] > pr[j])
            {
                int temp;

                temp = pr[i];
                pr[i] = pr[j];
                pr[j] = temp;

                temp = bt[i];
                bt[i] = bt[j];
                bt[j] = temp;

                temp = p[i];
                p[i] = p[j];
                p[j] = temp;
            }
        }
    }

    wt[0] = 0;

    for(int i = 1; i < n; i++)
        wt[i] = wt[i - 1] + bt[i - 1];

    printf("\nNon-Preemptive Priority Scheduling\n");
    printf("Process\tBT\tPriority\tWT\tTAT\n");

    for(int i = 0; i < n; i++)
    {
        tat[i] = wt[i] + bt[i];
        printf("P%d\t%d\t%d\t\t%d\t%d\n",
               p[i], bt[i], pr[i], wt[i], tat[i]);
    }
}

void preemptivePriority(int n, int bt[], int pr[])
{
    int rt[n], wt[n], tat[n];

    for(int i = 0; i < n; i++)
        rt[i] = bt[i];

    int complete = 0, time = 0;

    while(complete < n)
    {
        int highest = -1;

        for(int i = 0; i < n; i++)
        {
            if(rt[i] > 0)
            {
                if(highest == -1 || pr[i] < pr[highest])
                    highest = i;
            }
        }

        rt[highest]--;
        time++;

        if(rt[highest] == 0)
        {
            complete++;
            tat[highest] = time;
            wt[highest] = tat[highest] - bt[highest];
        }
    }

    printf("\nPreemptive Priority Scheduling\n");
    printf("Process\tBT\tPriority\tWT\tTAT\n");

    for(int i = 0; i < n; i++)
        printf("P%d\t%d\t%d\t\t%d\t%d\n",
               i + 1, bt[i], pr[i], wt[i], tat[i]);
}

int main()
{
    int n;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    int bt1[n], pr1[n], bt2[n], pr2[n];

    printf("Enter Burst Times:\n");
    for(int i = 0; i < n; i++)
    {
        scanf("%d", &bt1[i]);
        bt2[i] = bt1[i];
    }

    printf("Enter Priorities:\n");
    for(int i = 0; i < n; i++)
    {
        scanf("%d", &pr1[i]);
        pr2[i] = pr1[i];
    }

    nonPreemptivePriority(n, bt1, pr1);
    preemptivePriority(n, bt2, pr2);

    return 0;
}
